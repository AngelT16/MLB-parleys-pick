run = "npm run dev"
entrypoint = "client/src/App.tsx"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[env]
PORT = "5000"
MOCK_MODE = "true"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 3000

[deployment]
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm run build"]
